from django.http import JsonResponse
from django.views.decorators.http import require_GET
from .models import Product, Category

def product_to_dict(p):
    return {"id": p.id, "name": p.name, "price": p.price, "description": p.description, "count": p.count, "is_active": p.is_active, "category_id": p.category_id}

def category_to_dict(c):
    return {"id": c.id, "name": c.name}

@require_GET
def product_list(request):
    return JsonResponse([product_to_dict(p) for p in Product.objects.all()], safe=False)

@require_GET
def product_detail(request, id):
    try:
        return JsonResponse(product_to_dict(Product.objects.get(pk=id)))
    except Product.DoesNotExist:
        return JsonResponse({"error": "Not found"}, status=404)

@require_GET
def category_list(request):
    return JsonResponse([category_to_dict(c) for c in Category.objects.all()], safe=False)

@require_GET
def category_detail(request, id):
    try:
        return JsonResponse(category_to_dict(Category.objects.get(pk=id)))
    except Category.DoesNotExist:
        return JsonResponse({"error": "Not found"}, status=404)

@require_GET
def category_products(request, id):
    try:
        cat = Category.objects.get(pk=id)
        return JsonResponse([product_to_dict(p) for p in cat.products.all()], safe=False)
    except Category.DoesNotExist:
        return JsonResponse({"error": "Not found"}, status=404)
